#!/usr/bin/env bash
# Simulate `python3.12 -m venv <path>` for install.sh tests.
if [[ "$1" == "-m" && "$2" == "venv" && -n "$3" ]]; then
  mkdir -p "$3/bin"
  ln -sf "$(command -v python3)" "$3/bin/python" 2>/dev/null || true
  cat >"$3/bin/pip" <<'EOF'
#!/usr/bin/env bash
exit 0
EOF
  chmod +x "$3/bin/pip"
fi
exit 0
