// Template OpenCode config for the 4lm backend.
// install.sh copies this to ~/.config/opencode/opencode.jsonc on first run.
// Edit the installed copy; this file is the template.
//
// Model IDs must match what the active profile's backend serves:
//   omlx   backend → served_model_name from profile YAML
//   ollama backend → ollama pull tag (e.g. qwen3-coder-next:q4_K_M)
//   mlx_lm backend → model_path from profile YAML
//
// Pre-wired for the v0.6 `default` profile (omlx + full Qwen3 stack).
// Add or remove entries to match your active profile.
//
// Schema reference: https://opencode.ai/config.json
{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "4lm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local LLM (4lm)",
      "options": {
        "baseURL": "http://127.0.0.1:8000/v1"
      },
      "models": {
        // default / lean / max-100gb / mlx-coding profiles
        "qwen3-coder-next": { "name": "Qwen3-Coder-Next (build/code)" },
        // default / lean / mlx-knowledge profiles
        "qwen3.6-35b":      { "name": "Qwen3.6-35B-A3B (plan/chat)" },
        // max-100gb profile (chat tier upgrade)
        "qwen3-next-80b":   { "name": "Qwen3-Next-80B-A3B (heavy reasoning)" },
        // default / max-100gb profiles
        "qwen3-vl-8b":      { "name": "Qwen3-VL-8B (vision)" },
        // ollama profile (single-model smoke test)
        "qwen3-coder-next:q4_K_M": { "name": "Qwen3-Coder-Next GGUF (ollama)" }
      }
    }
  }
}
