// Template OpenCode config for the 4lm backend.
// install.sh copies this to ~/.config/opencode/opencode.jsonc on first run.
// Edit the installed copy; this file is the template.
//
// Schema reference: https://opencode.ai/config.json
{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "mlx-4lm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local MLX (4lm)",
      "options": {
        "baseURL": "http://127.0.0.1:8000/v1"
      },
      "models": {
        // default profile
        "qwen3-coder-30b": { "name": "Qwen3-Coder-30B (build/code)" },
        "qwen3.6-27b": { "name": "Qwen3.6-27B (plan/knowledge)" },
        "gpt-oss-120b": { "name": "GPT-OSS-120B (heavy reasoning, on-demand)" },
        // next profile
        "qwen3-coder-next": { "name": "Qwen3-Coder-Next (build/code)" },
        "qwen3-next-80b": { "name": "Qwen3-Next-80B (plan/knowledge/chat)" }
      }
    }
  }
}
